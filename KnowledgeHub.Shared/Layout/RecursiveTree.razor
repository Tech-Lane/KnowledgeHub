@* In KnowledgeHub.Shared/Layout/RecursiveTree.razor *@
@inject IStateService StateService
@using KnowledgeHub.Shared.Models
@using KnowledgeHub.Shared.Services

@foreach (var item in Items)
{
    @if (item.Type == "folder")
    {
        var folder = (Folder)item.Data;
        <div class="folder-item @GetSelectedClass(item)" @onclick="() => ToggleFolder(item)" data-id="@item.Id">
            <span class="folder-icon">
                <i class="fas @(expandedItems.Contains(item.Id) ? "fa-folder-open" : "fa-folder")"></i>
            </span>
            <span class="folder-name flex-grow-1">@item.Name</span>
        </div>

        @if (expandedItems.Contains(item.Id))
        {
            <div class="folder-content">
                @if (item.Children.Any())
                {
                    <RecursiveTree Items="item.Children" />
                }
                else
                {
                    <div class="p-2 small text-muted fst-italic">(empty)</div>
                }
            </div>
        }
    }
    else // It's a note
    {
        var note = (Note)item.Data;
        <div class="note-item @GetSelectedClass(item)" @onclick="() => SelectNote(item)" data-id="@item.Id">
            <span class="note-icon"><i class="fas fa-file-alt"></i></span>
            <span class="note-title">@item.Name</span>
        </div>
    }
}

@code {
    [Parameter]
    public List<TreeItem> Items { get; set; } = new();

    private HashSet<string> expandedItems = new();
    private string? selectedItemId => (StateService.SelectedItem as TreeItem)?.Id;

    private void ToggleFolder(TreeItem folder)
    {
        if (expandedItems.Contains(folder.Id))
        {
            expandedItems.Remove(folder.Id);
        }
        else
        {
            expandedItems.Add(folder.Id);
        }
        StateService.SetSelectedItem("folder", folder);
    }

    private void SelectNote(TreeItem note)
    {
        StateService.SetSelectedItem("note", note);
    }

    private string GetSelectedClass(TreeItem item)
    {
        return item.Id == selectedItemId ? "selected" : "";
    }
}