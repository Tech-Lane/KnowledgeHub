@* In KnowledgeHub.Shared/Components/ViewManager.razor *@
@using KnowledgeHub.Shared.Models
@using KnowledgeHub.Shared.Services
@inject IStateService StateService
@implements IDisposable

@switch (StateService.CurrentViewType)
{
    case "note":
        <NoteEditor />
        break;
    case "folder":
        <div class="text-center text-muted mt-5">
            <i class="fas fa-folder-open fa-3x mb-4"></i>
            <p class="h5">Folder Selected</p>
        </div>
        break;
    case "dashboard":
        if (StateService.SelectedItem is Dashboard dashboard)
        {
            <DashboardView Dashboard="dashboard" />
        }
        else
        {
            <div class="text-center text-muted mt-5">
                <i class="fas fa-tachometer-alt fa-3x mb-4"></i>
                <p class="h5">Loading Dashboard...</p>
            </div>
        }
        break;
    default:
        @ChildContent
        break;
}

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    protected override void OnInitialized()
    {
        StateService.OnChange += OnStateChanged;
    }

    private void OnStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        StateService.OnChange -= OnStateChanged;
    }
} 