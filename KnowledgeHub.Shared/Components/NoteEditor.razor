@* In KnowledgeHub.Shared/Components/NoteEditor.razor *@
@inject IStateService StateService
@inject INoteDataService NoteDataService
@inject IJSRuntime JSRuntime
@implements IDisposable
@using KnowledgeHub.Shared.Models
@using KnowledgeHub.Shared.Services
@using System.Text.RegularExpressions
@using System.Linq

@if (activeNote != null)
{
    <div class="note-editor-container p-3">
        <div class="note-editor-toolbar d-flex justify-content-between align-items-center mb-3 p-2 border-bottom">
            <div class="d-flex gap-2">
                <button @onclick="SaveChanges" class="btn btn-sm btn-success d-flex align-items-center">
                    <i class="fas fa-save me-1"></i> Save
                </button>
                <button @onclick="() => isTableModalVisible = true" class="btn btn-sm btn-primary d-flex align-items-center">
                    <i class="fas fa-table me-1"></i> Add Table
                </button>
                <button @onclick="ProcessReferences" class="btn btn-sm btn-info d-flex align-items-center">
                    <i class="fas fa-cogs me-1"></i> Process Refs
                </button>
            </div>
            <div>
                <button @onclick="DeleteNote" class="btn btn-sm btn-danger d-flex align-items-center">
                    <i class="fas fa-trash-alt me-1"></i> Delete
                </button>
            </div>
        </div>

        <input @bind="activeNote.Title" @bind:event="oninput" class="form-control form-control-lg mb-3" placeholder="Note Title" />

        <textarea @bind="activeNote.Content" @bind:event="oninput" class="form-control" style="height: 300px;"></textarea>
        
        <div class="tables-section mt-4">
            @foreach (var table in activeNote.Tables)
            {
                <TableView Table="table" />
            }
        </div>

        @if (isTableModalVisible)
        {
            <div class="modal-backdrop">
                <div class="modal-content">
                    <TableDefinitionModal OnCreateTable="HandleCreateTable" OnCancel="() => isTableModalVisible = false" />
                </div>
            </div>
        }
    </div>
}
else if (isLoading)
{
    <div class="text-center p-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2">Loading note...</p>
    </div>
}

@code {
    private Note? activeNote;
    private bool isLoading = false;
    private bool isTableModalVisible = false;

    // When the component is created, subscribe to state changes
    protected override void OnInitialized()
    {
        StateService.OnChange += HandleStateChange;
    }

    private void HandleCreateTable(Table newTable)
    {
        if (activeNote != null)
        {
            newTable.NoteId = activeNote.Id;
            activeNote.Tables.Add(newTable);
            StateHasChanged();
        }
        isTableModalVisible = false;
    }

    private async void HandleStateChange()
    {
        // This will be invoked when the state changes.
        // We use InvokeAsync to ensure the UI updates are dispatched correctly,
        // especially when the state change is triggered from a different render mode.
        await InvokeAsync(async () =>
        {
            var selectedTreeItem = StateService.SelectedItem as TreeItem;

            // Do nothing if the selected note is already the active one
            if (selectedTreeItem != null && selectedTreeItem.Type == "note" && activeNote != null && selectedTreeItem.Id == "note-" + activeNote.Id)
            {
                return;
            }

            if (selectedTreeItem?.Type == "note" && selectedTreeItem.Data is Note noteData)
            {
                isLoading = true;
                StateHasChanged();

                var newNote = await NoteDataService.GetNoteAsync(noteData.Id);
                activeNote = newNote;
                isLoading = false;
                StateHasChanged();
            }
            else
            {
                activeNote = null;
                StateHasChanged();
            }
        });
    }

    private async Task SaveChanges()
    {
        if (activeNote != null)
        {
            await NoteDataService.UpdateNoteAsync(activeNote);
            // We might want to add a "Saved!" confirmation message later
        }
    }

    private async Task DeleteNote()
    {
        if (activeNote != null)
        {
            var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this note?");
            if (confirmed)
            {
                await NoteDataService.DeleteNoteAsync(activeNote.Id);
                StateService.SetSelectedItem("welcome", null); // Refresh the UI
            }
        }
    }

    private async Task ProcessReferences()
    {
        if (activeNote?.Content == null) return;

        var regex = new Regex(@"\{\{\s*(?<tableName>\w+)\.(?<columnName>\w+)\.(?<aggregation>\w+)\s*\}\}");
        var matches = regex.Matches(activeNote.Content);

        var updatedContent = activeNote.Content;

        foreach (Match match in matches)
        {
            var tableName = match.Groups["tableName"].Value;
            var columnName = match.Groups["columnName"].Value;
            var aggregation = match.Groups["aggregation"].Value.ToLower();

            var table = activeNote.Tables.FirstOrDefault(t => t.Name.Equals(tableName, StringComparison.OrdinalIgnoreCase));
            if (table == null) continue;

            var result = await TableValueCalculator.Calculate(table, columnName, aggregation);
            updatedContent = updatedContent.Replace(match.Value, result);
        }

        activeNote.Content = updatedContent;
        StateHasChanged();
    }

    // Unsubscribe from the event when the component is destroyed to prevent memory leaks
    public void Dispose()
    {
        StateService.OnChange -= HandleStateChange;
    }
}

<style>
    .modal-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: rgba(0, 0, 0, 0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1050;
    }

    .modal-content {
        width: 90%;
        max-width: 600px;
        background-color: white;
        padding: 1.5rem;
        border-radius: var(--border-radius);
        box-shadow: var(--box-shadow);
    }
</style>